{
  "redirects": [
    {
      "source": "/admin.html",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/dashboard.html",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/app.html",
      "destination": "/",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(admin|dashboard).html",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ]
}
